{{- /* --- LOGIC BLOCK START --- */ -}}
{{- $realHostname := output "hostname" | trim -}}
{{- $decrypted := include "bootstrap_secrets.json.age" | decrypt -}}
{{- $cleaned := $decrypted | replaceAllRegex "\x1b\\[[0-9;]*[a-zA-Z]" "" | replaceAllRegex "\x1b" "" | trim -}}
{{- $bootstrap := $cleaned | fromJson -}}

{{- /* Handle Domain Switching */ -}}
{{- $infisicalBin := "infisical" -}}
{{- $domain := $bootstrap.domain -}}

{{- if eq $realHostname "raspberrypi" -}}
  {{- $infisicalBin = "/home/cparrish/.local/bin/infisical" -}}
  {{- $domain = "http://127.0.0.1:8081" -}}
{{- end -}}

{{- $loginToken := output $infisicalBin "login" "--method=universal-auth" "--client-id" $bootstrap.clientId "--client-secret" $bootstrap.clientSecret "--domain" $domain "--plain" "--silent" | trim -}}
{{- $secrets := dict -}}
{{- $rawJSON := output $infisicalBin "export" "--env" "dev" "--projectId" $bootstrap.projectId "--token" $loginToken "--domain" $domain "--format" "json" "--silent" | trim -}}
{{- range ($rawJSON | fromJson) -}}
    {{- $_ := set $secrets .key .value -}}
{{- end -}}
{{- /* --- LOGIC BLOCK END --- */ -}}

encryption = "age"

[age]
    identity = "~/.config/chezmoi/yubikey-identity.txt"
    recipient = "age1yubikey1q2mm9uxwlf03r37500kz3rtak6g5d8wuuqnkquspslqg6n20x7zsukw42wa"

[data]
    hostname = {{ $realHostname | quote }}

[data.infisical]
  projectId = {{ $bootstrap.projectId | quote }}
  clientId = {{ $bootstrap.clientId | quote }}
  clientSecret = {{ $bootstrap.clientSecret | quote }}

[data.secrets]
{{- range $k, $v := $secrets }}
    {{ $k }} = {{ $v | quote }}
{{- end }}
