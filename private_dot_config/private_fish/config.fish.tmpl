# ~/.config/fish/config.fish
# Generated by Chezmoi for {{ .chezmoi.os }}
{{- $is_chromebook := false -}}
{{- if (and (eq .chezmoi.os "linux") (contains "penguin" .chezmoi.hostname)) -}}
  {{- $is_chromebook = true -}}
{{- end -}}
# =========================
# Basic editor & colors
# =========================
set -gx EDITOR nvim
set -gx EZA_COLORS "da=34:di=34:ex=32:fi=0:ln=36:or=31:pi=33:so=35:su=31:tw=31"
set -gx STARSHIP_CONFIG "$HOME/.config/starship/starship.toml"

# ========================
# Trust the Chezmoi Vault in Mise
# =======================
set -gx MISE_TRUSTED_CONFIG_PATHS "{{ .chezmoi.sourceDir }}"

# =========================
# Homebrew (macOS Only)
# =========================
{{- if eq .chezmoi.os "darwin" }}
if test -x /opt/homebrew/bin/brew
    eval "$(/opt/homebrew/bin/brew shellenv)"
end

# Mac-specific Mise locations
set -gx MISE_DATA_DIR $HOME/.local/share/mise
set -gx MISE_CONFIG_DIR $HOME/.config/mise
set -gx MISE_CACHE_DIR $HOME/.cache/mise

{{- end }}


# =========================
# PATH setup
# =========================
# fish_add_path handles deduplication automatically
fish_add_path $HOME/.cargo/bin
fish_add_path $HOME/.local/bin
fish_add_path $HOME/.local/bin/zen/zen
fish_add_path -a /usr/local/bin
fish_add_path /usr/local/go/bin
fish_add_path $HOME/go/bin

# Antigravity (Added dynamically if present)
if test -d "$HOME/.antigravity/antigravity/bin"
    fish_add_path "$HOME/.antigravity/antigravity/bin"
end

# Google Cloud
if test -d "$HOME/google-cloud-sdk/bin/"
    fish_add_path -a "$HOME/google-cloud-sdk/bin/"
end


# =========================
# Aliases
# =========================
if test -f ~/.config/fish/aliases/common.fish
    source ~/.config/fish/aliases/common.fish
end


# =========================
# Secrets (Infisical Placeholder)
# =========================
# Note: Previous secrets.fish source removed.
# TODO: Add 'infisical run -- fish' wrapper or export logic here later.

# =========================
# Interactive-only init
# =========================
if status is-interactive
    # Set TTY for GPG pinentry prompts
    set -x GPG_TTY (tty)

    # 1. mise FIRST (so all managed tools are in PATH)
    if type -q mise
        mise activate fish | source
    end

    # 2. Atuin
    if type -q atuin
        atuin init fish | source
    end

    # 3. Starship
    if type -q starship
        starship init fish | source
    end

    # 4. Jujutsu Workspace Manager (jjw)
    #if type -q jjw
    #    jjw init fish | source
    #end

    # 5. Zoxide
    if type -q zoxide
        # Configure fzf options specifically for interactive zoxide selection
        set -gx ZOXIDE_INTERACTIVE_CMD "fzf --height 50% --reverse --inline-info \
         --preview 'eza --tree --level=2 --color=always --icons {} | head -30'"
        zoxide init fish | source
        function cd
            if test (count $argv) -eq 0
                builtin cd $HOME
                return
            end

            # 1. Determine where zoxide *would* send us if we run 'z argv'
            set -l target (zoxide query --exclude "$PWD" -- $argv 2>/dev/null)

            if test -n "$target"
                # 2. See if we are in a Git/Jujutsu repository
                set -l current_root (git rev-parse --show-toplevel 2>/dev/null)
                
                if test -n "$current_root"
                    # 3. See if the target destination is also in a repository
                    set -l target_root (git -C "$target" rev-parse --show-toplevel 2>/dev/null)

                    if test -n "$target_root"
                        # 4. Check if both directories share the same underlying repository database
                        set -l current_common (git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
                        set -l target_common (git -C "$target" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)

                        if test "$current_common" = "$target_common"
                            # 5. Rewrite target path to stay inside our active workspace
                            set -l relative_path (string replace -r "^$target_root/?" "" $target)
                            set -l local_target "$current_root/$relative_path"

                            # If that folder exists in our current workspace, redirect there!
                            if test -d "$local_target"
                                set target "$local_target"
                            end
                        end
                    end
                end

                builtin cd $target; and zoxide add $PWD
                else
                # Fall back to standard builtin cd if zoxide has no match
                builtin cd $argv
            end
        end
    end


  # 6. Vi key bindings
  fish_vi_key_bindings
end

# =========================
# Machine-Specific Tweaks
# =========================

{{- /* Mac Mini Specifics */}}
{{- if eq .chezmoi.hostname "Mac-mini" }}
# Starship config path override
set -gx STARSHIP_CONFIG $HOME/.config/starship/starship.toml

# WezTerm background image
set -gx shellBgImagePath "$HOME/.config/wezterm/images/d3Logo.png"

if set -q WEZTERM_PANE
    # Ensure the command is formatted correctly for modern WezTerm CLI
    wezterm cli set-user-var shellBgImagePath "$shellBgImagePath" > /dev/null 2>&1
end

{{- end }}

