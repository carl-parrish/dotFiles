[tools]
# --- Core Languages ---
go = "1.25.4"
node = "20"
python = "3.12"
ruby = "3.3"
rust = "latest"

# --- Kubernetes & CKA Study ---
# Version locked for exam consistency
kubectl = "1.31.0"
opentofu = "1.7.0"

{{- if eq .chezmoi.os "darwin" }}
# macOS Only: Study & Runtime
minikube = "1.33.1"
"aqua:abiosoft/colima" = "latest"
{{- end }}


# --- Node Packages ---
"npm:pnpm" = "latest"
"npm:typescript" = "latest"
"npm:@google/gemini-cli" = "latest"
"npm:@bitwarden/cli" = "latest"

# --- Cargo/Rust Tools (Compiled) ---
# Keeping 'cargo' to ensure ARM64 compatibility on Linux/Pi
"cargo:spec-kit-mcp" = "latest"
"cargo:eza" = "latest"
"cargo:ripgrep" = "latest"
"cargo:nu" = "latest"
"cargo:jj-cli" = "latest"

# --- Universal Binaries (Fast Install) ---
"ubi:sharkdp/bat" = "latest"
"ubi:ajeetdsouza/zoxide" = "latest"
"ubi:bcicen/ctop" = "latest"
"ubi:cjbassi/gotop" = "latest"
"ubi:junegunn/fzf" = "latest"
"ubi:starship/starship" = "latest"
"ubi:zellij-org/zellij" = "latest"
"ubi:sharkdp/fd" = "latest"
"ubi:lsd-rs/lsd" = "latest"
"ubi:ducaale/xh" = "latest"
"ubi:a8m/envsubst" = "latest"

# --- GitHub Binaries ---
"github:ActivityWatch/activitywatch" = "latest"
"github:kopia/kopia" = "latest"
"github:str4d/age-plugin-yubikey" = "latest"
"github:cli/cli" = "2.89.0"


# Stand alone Providers
atuin = "latest"
infisical = "latest"
sops = "latest"
age = "latest"
rclone = "1.73.1"

[settings]
autoinstall = true
