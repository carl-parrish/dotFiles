[tools]
# --- Core Languages ---
go = "1.25.4"
node = "22.21.0"
python = "3.12"
ruby = "3.3"
rust = "1.92.0"

# --- Kubernetes & CKA Study ---
# Version locked for exam consistency
kubectl = "1.31.0"
opentofu = "1.7.0"

{{- if eq .chezmoi.os "darwin" }}
# macOS Only: Study & Runtime
minikube = "1.33.1"
"github:abiosoft/colima" = "latest"
"github:lima-vm/lima" = "latest"
"github:str4d/age-plugin-yubikey" = "latest"
"npm:mcp-cron-darwin-arm64" = "latest"

{{- else }}
# Compiles on the Pi / Linode
"cargo:age-plugin-yubikey" = "latest"
"cargo:btop" = "latest"
{{- end }}


# --- Node Packages ---
"npm:pnpm" = "latest"
"npm:typescript" = "latest"
"npm:@google/gemini-cli" = "latest"
"npm:@bitwarden/cli" = "latest"
"npm:@earendil-works/pi-coding-agent" = "latest"
"npm:@a5c-ai/babysitter-sdk" = "0.0.187"
"npm:clerk" = "latest"

{{- if ne .chezmoi.os "darwin" }}
# Generic MCP Cron for Linux nodes (avoids EBADPLATFORM)
"npm:schedule-task-mcp" = "latest"
{{- end }}

{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.arch "arm64") }}
# --- Pi / ARM Linux (Compile for safety) ---
"cargo:zellij" = "latest"
"cargo:zoxide" = "latest"
"cargo:lsd" = "latest"
"cargo:bat" = "latest"
"cargo:fd-find" = "latest"
"cargo:starship" = "latest"

{{- else }}
# --- Mac / Mint-Mini (Use stable binaries) ---
"github:zellij-org/zellij" = "latest"
"github:ajeetdsouza/zoxide" = "latest"
"github:lsd-rs/lsd" = "latest"
"github:sharkdp/bat" = "latest"
"github:sharkdp/fd" = "latest"
"github:starship/starship" = "latest"
{{- end }}

# --- Cargo/Rust Tools (Compiled) ---
# Keeping 'cargo' to ensure ARM64 compatibility on Linux/Pi
"cargo:eza" = "latest"
"cargo:ripgrep" = "latest"
"cargo:nu" = "latest"
"cargo:jj-cli" = "latest"
"cargo:dua-cli" = "latest"
"cargo:du-dust" = "latest"
"cargo:spec-kit-mcp" = "latest"
"cargo:jj-starship" = "latest"
"cargo:scm-diff-editor" = "latest"
"cargo:presenterm" = "latest"

# --- Python Tools (Isolated via Pipx) ---
uv = "latest"
"pipx:black" = "latest"
"pipx:ansible-core" = "latest"
"pipx:hermes-agent" = "latest"

# --- Universal Binaries (Fast Install) ---
# --- GitHub Binaries ---
"github:ActivityWatch/activitywatch" = "latest"
"github:kopia/kopia" = "latest"
"github:astral-sh/ruff" = "latest"
"github:junegunn/fzf" = "latest"
"github:ducaale/xh" = "latest"
"github:a8m/envsubst" = "latest"
"github:ClementTsang/bottom" = "latest"
"github:jesseduffield/lazydocker" = "latest"
"github:jqlang/jq" = "latest"
"github:sst/opencode" = "latest"   # Installs the high-performance Go binary

# -- Go Packages --
"go:github.com/cli/cli/v2/cmd/gh" = "latest"
"go:github.com/nats-io/natscli/nats" = "latest"
"go:github.com/simulot/immich-go" = "latest"
"go:codeberg.org/romaintb/fgj" = "latest"

# Stand alone Providers
atuin = "latest"
infisical = "latest"
sops = "latest"
age = "latest"
rclone = "1.73.1"
terraform-ls = "latest"


